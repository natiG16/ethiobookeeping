# Database (Docker Compose uses POSTGRES_* for the postgres service)
POSTGRES_DB=ethiobooks
POSTGRES_USER=ethiobooks
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_PORT=5432

# Local Maven runs (optional; Compose sets DB_URL automatically)
DB_URL=jdbc:postgresql://localhost:5432/ethiobooks
DB_USERNAME=ethiobooks
DB_PASSWORD=ethiobooks

# Docker / VPS ports (production: WEB_PORT=80, do not expose API_PORT publicly)
WEB_PORT=80
API_PORT=8080
UPLOAD_DIR=/data/uploads

# JWT (use a strong random secret in production, min 256 bits)
JWT_SECRET=sFS0y9qo8cCNw5NYL0xirD1Uv2pr8sG73FbH47NvQKZ
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# API
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:3000
FRONTEND_URL=http://localhost:4200

# Email (signup verification)
# Option A — dev: MailHog on localhost:1025 (no auth)
# MAIL_HOST=localhost
# MAIL_PORT=1025
# MAIL_FROM=mysuq <noreply@localhost>

# Option B — Gmail (until you switch to production SMTP)
# 1) Google Account → Security → 2-Step Verification ON
# 2) App passwords → create one for "Mail" → use the 16-character password below
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=mysuq <you@gmail.com>

# Google Sign-In — OAuth 2.0 Client IDs from Google Cloud Console
# Comma-separated: Web client, Android client, iOS client as needed
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com

# Phone OTP (dev) - delivered via Telegram bot for now
OTP_SECRET=change-me-otp-secret
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_MAX_SENDS_10M=3

# Telegram delivery (create a bot via @BotFather, then set bot token + chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin support panel (created/updated on backend startup)
ADMIN_EMAIL=admin@mysuq.local
ADMIN_PASSWORD=change-me-admin-password

# Customer support (shown in app UI — set matching values in web/src/environments/environment*.ts)
# SUPPORT_EMAIL=support@mysuq.local
# SUPPORT_PHONE=+251911234567
# SUPPORT_TELEGRAM=@your_support_bot
# SUPPORT_CENTER_URL=https://mysuq.local/support
